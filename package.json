{
  "name": "bombapvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "check:cloudflare": "npm run build && wrangler deploy --dry-run",
    "deploy:cloudflare": "npm run build && wrangler deploy",
    "dev:cloudflare": "npm run build && wrangler dev",
    "test": "vitest run --environment happy-dom",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.original-game.json",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "happy-dom": "20.10.6",
    "typescript": "5.9.2",
    "vite": "7.3.6",
    "vitest": "3.2.7",
    "wrangler": "4.111.0"
  }
}
