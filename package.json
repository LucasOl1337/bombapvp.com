{
  "name": "bombapvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.game-mechanics.json",
    "test": "vitest run --project=contracts-node",
    "test:mechanics": "vitest run --project=contracts-node",
    "build": "npm run typecheck && vite build",
    "check": "npm run typecheck && npm run test && vite build"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "5.9.2",
    "vite": "7.3.6",
    "vitest": "3.2.7",
    "wrangler": "4.111.0"
  },
  "dependencies": {
    "@fontsource/inter": "5.2.8",
    "@fontsource/space-grotesk": "5.2.10"
  }
}
