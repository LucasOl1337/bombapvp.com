{
  "name": "bombapvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "test:mechanics": "vitest run GameMechanics/tests/game-mechanics.test.ts --project=contracts-node",
    "check:mechanics": "tsc --noEmit -p tsconfig.game-mechanics.json && npm run test:mechanics",
    "build": "npm run typecheck && vite build",
    "check:cloudflare": "npm run build && npm run audit:online-worker-bundle",
    "audit:online-worker-bundle": "node scripts/audit-online-worker-bundle.mjs",
    "deploy:cloudflare": "npm run build && wrangler deploy",
    "dev:cloudflare": "npm run build && wrangler dev",
    "lab:broker": "powershell -ExecutionPolicy Bypass -File scripts/start-lab-broker.ps1",
    "lab:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-lab-tunnel.ps1",
    "test": "npm run test:full",
    "test:contracts": "vitest run --project=contracts-node",
    "test:ui": "vitest run --project=contracts-ui",
    "test:gates": "vitest run --project=gates-node --no-file-parallelism",
    "test:full": "npm run test:contracts && npm run test:ui && npm run test:gates",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.original-game.json",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "happy-dom": "20.10.6",
    "typescript": "5.9.2",
    "vite": "7.3.6",
    "vitest": "3.2.7",
    "wrangler": "4.111.0"
  },
  "dependencies": {
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/inter": "5.2.8",
    "@fontsource/space-grotesk": "5.2.10"
  }
}
